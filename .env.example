# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=database_name

# Base de datos MongoDB (para logs)
MONGODB_URI=mongodb://localhost:port/database_name

# JWT
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui
JWT_EXPIRES_IN=24h

# Email (Brevo)
BREVO_API_KEY=brevo_api_key_aqui
BREVO_SENDER_EMAIL=noreply@tudominio.com
BREVO_SENDER_NAME=Sistema de Turnos

# Aplicación
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Configuración de invitaciones
INVITATION_TOKEN_EXPIRES_IN=48h
TEMP_PASSWORD_LENGTH=8
